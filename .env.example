# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno del proyecto Aduana BI.
# Copiá este archivo como ".env" y completá los valores reales.
# El archivo .env NUNCA se sube al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# --- PostgreSQL (contenedor Docker "aduana_db") ---
POSTGRES_USER=aduana
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=aduana_bi
POSTGRES_PORT=5444
POSTGRES_HOST=localhost
